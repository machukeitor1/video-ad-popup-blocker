{
  "manifest_version": 3,
  "name": "Video Ad Popup Blocker",
  "version": "1.0",
  "description": "Bloquea ventanas emergentes (pop-ups) de publicidad al intentar reproducir videos.",
  "icons": {
    "16": "logo.png",
    "48": "logo.png",
    "128": "logo.png"
  },
  "permissions": [
    "scripting",
    "activeTab"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true
  "web_accessible_resources": [
    {
      "resources": ["page.js"],
      "matches": ["<all_urls>"]
    }
  ]
}

  ]
}
